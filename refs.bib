@inproceedings{10.1145/3610251.3610561,
author = {Monga, Inder and Saglamyurek, Erhan and Kissel, Ezra and Haffner, Hartmut and Wu, Wenji},
title = {QUANT-NET: A testbed for quantum networking research over deployed fiber},
year = {2023},
isbn = {9798400703065},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3610251.3610561},
doi = {10.1145/3610251.3610561},
abstract = {QUANT-NET is a three-node quantum network research testbed funded by the U.S. Department of Energy (DOE). The goal is to establish this network between two sites, Lawrence Berkeley National Lab (LBNL) and University of California, Berkeley, connected with an entanglement swapping substrate over optical fiber and managed by a quantum network protocol stack. On top of this entanglement swapping substrate the research team will implement the most basic building blocks of distributed quantum computing and quantum repeater by teleporting a controlled-NOT gate between two far trapped-ion quantum computation nodes. This paper presents QUANT-NET, its design, key technologies, and progress.},
booktitle = {Proceedings of the 1st Workshop on Quantum Networks and Distributed Quantum Computing},
pages = {31–37},
numpages = {7},
keywords = {quantum internet, quantum network},
location = {New York, NY, USA},
series = {QuNet '23}
}

